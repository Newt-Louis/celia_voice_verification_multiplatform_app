{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Celia Voice Verification",
  "version": "0.1.0",
  "identifier": "dev.celia.voice-verification",
  "build": {
    "beforeDevCommand": "npm --prefix frontend run dev",
    "beforeBuildCommand": "npm --prefix frontend run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Celia Voice Verification",
        "width": 1100,
        "height": 760,
        "minWidth": 360,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "resources": [
      "../models/v2_int8_fast/ecapa_int8_dynamic.onnx",
      "../models/q5_0/ggml-model-q5_0.bin"
    ]
  }
}
